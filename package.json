{
  "name": "memory",
  "version": "2.0.0",
  "description": "Memory tool for AI agents — store, search, and link memories with SQLite-vec vector search",
  "type": "module",
  "main": "dist/src/cli.js",
  "bin": {
    "memory": "./dist/bin/memory.js",
    "mcp-memory": "./dist/mcp-server.js"
  },
  "files": [
    "dist/",
    "commands/"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/bin/memory.js",
    "dev": "tsx bin/memory.ts",
    "mcp": "tsx mcp-server.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "memory",
    "ai",
    "agent",
    "mcp",
    "wiki",
    "vector-search",
    "sqlite-vec"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "extract-zip": "^2.0.1",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "inquirer": "^10.2.0",
    "simple-git": "^3.25.0",
    "slugify": "^1.6.6",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/extract-zip": "^2.0.2",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
